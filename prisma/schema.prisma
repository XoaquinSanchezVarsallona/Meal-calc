// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Meal {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?

  user_meals       UserMeal[]
  meal_ingredients MealIngredient[]
}

model Ingredient {
  id       String @id @default(uuid()) @db.Uuid
  name     String
  calories Int

  user_ingredients UserIngredient[]
  meal_ingredients MealIngredient[]
}

model User {
  id        String @id @default(uuid()) @db.Uuid
  email     String @unique
  password  String
  weight_kg Float
  height_cm Float
  age       Int
  gender    Gender

  user_meals       UserMeal[]
  user_ingredients UserIngredient[]
}

model UserMeal {
  user_id String @db.Uuid
  meal_id String @db.Uuid

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  meal Meal @relation(fields: [meal_id], references: [id], onDelete: Cascade)

  @@id([user_id, meal_id])
  @@index([meal_id])
}

model UserIngredient {
  user_id        String @db.Uuid
  ingredient_id   String @db.Uuid
  quantity_kg     Float?

  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredient_id], references: [id], onDelete: Cascade)

  @@id([user_id, ingredient_id])
  @@index([ingredient_id])
}

model MealIngredient {
  meal_id       String @db.Uuid
  ingredient_id String @db.Uuid
  quantity_kg   Float?

  meal       Meal       @relation(fields: [meal_id], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredient_id], references: [id], onDelete: Cascade)

  @@id([meal_id, ingredient_id])
  @@index([ingredient_id])
}

enum Gender {
  MALE
  FEMALE
}
